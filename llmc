#!/usr/bin/env bash
#
# llmc — Launch an LLM coding assistant with a local or cloud model.
# Usage: llmc [claude|codex|opencode|aider] [local-llm-url]  (defaults: claude, http://localhost:1234)
#
set -euo pipefail

# ── Configuration ──────────────────────────────────────────────────
LM_STUDIO_URL="http://localhost:1234"
LM_STUDIO_MODELS_API="${LM_STUDIO_URL}/api/v1/models"
LLMC_CONFIG="${HOME}/.llmc/config.json"

# ── Helpers ────────────────────────────────────────────────────────
save_env() {
  local backup_file
  backup_file="$(mktemp)"
  for var in ANTHROPIC_MODEL ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN ANTHROPIC_API_KEY \
             OPENAI_MODEL OPENAI_BASE_URL OPENAI_API_KEY \
             OPENCODE_CONFIG; do
    if [[ -n "${!var:-}" ]]; then
      echo "${var}=${!var}" >> "$backup_file"
    else
      echo "# No ${var} was set" >> "$backup_file"
    fi
  done
  echo "$backup_file"
}

restore_env() {
  local backup_file="$1"
  if [[ -f "$backup_file" ]]; then
    unset ANTHROPIC_MODEL ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN ANTHROPIC_API_KEY \
          OPENAI_MODEL OPENAI_BASE_URL OPENAI_API_KEY \
          OPENCODE_CONFIG 2>/dev/null || true
    while IFS='=' read -r key value; do
      [[ "$key" =~ ^# ]] && continue
      [[ -z "$key" ]] && continue
      export "$key"="$value"
    done < "$backup_file"
    rm -f "$backup_file"
    ENV_BACKUP_FILE=""
  fi
}

is_local() {
  [[ "$LM_STUDIO_URL" =~ ^https?://(localhost|127\.[0-9]+\.[0-9]+\.[0-9]+)(:[0-9]+)?(/.*)?$ ]]
}

cleanup() {
  if [[ -n "${PROXY_PID:-}" ]]; then
    kill "$PROXY_PID" 2>/dev/null || true
    PROXY_PID=""
  fi
  [[ -n "${PROXY_SCRIPT:-}" ]] && { rm -f "$PROXY_SCRIPT"; PROXY_SCRIPT=""; }
  if [[ -n "${OPENCODE_CONFIG_FILE:-}" ]]; then
    rm -f "$OPENCODE_CONFIG_FILE"
    OPENCODE_CONFIG_FILE=""
  fi
  if [[ -n "${LOADED_LOCAL_MODEL:-}" ]] && is_local && command -v lms >/dev/null 2>&1; then
    echo ""
    echo "Unloading local model: ${LOADED_LOCAL_MODEL}..."
    lms unload --all 2>/dev/null || true
  fi
  if [[ -n "${LMS_DAEMON_STARTED:-}" ]] && command -v lms >/dev/null 2>&1; then
    echo ""
    echo "Stopping LM Studio daemon..."
    lms daemon down 2>/dev/null || true
  fi
  if [[ -n "${ENV_BACKUP_FILE:-}" ]]; then
    restore_env "$ENV_BACKUP_FILE"
    echo "[$(date '+%H:%M:%S')] Restored original environment."
  fi
}

# ── Start a LiteLLM proxy (Anthropic→OpenAI translation gateway) ────
# LiteLLM exposes an Anthropic-compatible /v1/messages endpoint and
# translates requests to the upstream OpenAI-compatible provider.
# Sets PROXY_PORT on success.
start_litellm_proxy() {
  local model="$1"     # bare model id, e.g. Qwen/Qwen3.6-35B-A3B
  local base_url="$2"  # provider base URL
  local api_key="$3"

  if ! command -v litellm >/dev/null 2>&1; then
    echo "" >&2
    echo "  Error: 'litellm' is required for external cloud providers." >&2
    echo "  Install: uv tool install 'litellm[proxy]'" >&2
    echo "" >&2
    return 1
  fi

  # Find a free port
  PROXY_PORT=$(python3 -c \
    "import socket; s=socket.socket(); s.bind(('',0)); print(s.getsockname()[1]); s.close()")

  # Write a temporary LiteLLM config.
  # OpenRouter has a native litellm provider (openrouter/) that avoids the
  # provider-filtering bug that occurs when using the generic openai/ prefix
  # with an openrouter.ai base_url.
  PROXY_SCRIPT="$(mktemp /tmp/llmc-litellm.XXXXXX.yaml)"
  if [[ "$base_url" == *"openrouter.ai"* ]]; then
    cat > "$PROXY_SCRIPT" << YAML
model_list:
  - model_name: "${model}"
    litellm_params:
      model: "openrouter/${model}"
      api_key: "${api_key}"

litellm_settings:
  drop_params: true
YAML
  else
    cat > "$PROXY_SCRIPT" << YAML
model_list:
  - model_name: "${model}"
    litellm_params:
      model: "openai/${model}"
      api_base: "${base_url}"
      api_key: "${api_key}"

litellm_settings:
  drop_params: true
YAML
  fi

  LITELLM_USE_CHAT_COMPLETIONS_URL_FOR_ANTHROPIC_MESSAGES=true \
    litellm --config "$PROXY_SCRIPT" --port "$PROXY_PORT" \
    > /tmp/llmc-litellm.log 2>&1 &
  PROXY_PID=$!

  # Wait until the health endpoint responds (up to 20 s)
  local elapsed=0
  while (( elapsed < 100 )); do
    curl -sf "http://127.0.0.1:${PROXY_PORT}/health" >/dev/null 2>&1 && break
    sleep 0.2
    (( elapsed++ ))
  done

  if ! curl -sf "http://127.0.0.1:${PROXY_PORT}/health" >/dev/null 2>&1; then
    echo "Error: litellm proxy did not start (check /tmp/llmc-litellm.log)" >&2
    return 1
  fi
}

# ── Fetch local models from LM Studio ──────────────────────────────
fetch_local_models() {
  local json
  json="$(curl -s "$LM_STUDIO_MODELS_API" 2>/dev/null)" || {
    echo ""
    return 1
  }
  echo "$json"
}

# Format a human-readable size string
format_size() {
  local bytes="$1"
  if (( bytes >= 1073741824 )); then
    printf "%.1f GB" "$(echo "scale=1; $bytes / 1073741824" | bc)"
  elif (( bytes >= 1048576 )); then
    printf "%.1f MB" "$(echo "scale=1; $bytes / 1048576" | bc)"
  else
    printf "%d KB" "$(echo "scale=0; $bytes / 1024" | bc)"
  fi
}

