#!/usr/bin/env bash
#
# llmc — Launch an LLM coding assistant with a local or cloud model.
# Usage: llmc [claude|codex|opencode|aider] [local-llm-url]  (defaults: claude, http://localhost:1234)
#
set -euo pipefail

# ── Configuration ──────────────────────────────────────────────────
LM_STUDIO_URL="http://localhost:1234"
LM_STUDIO_MODELS_API="${LM_STUDIO_URL}/api/v1/models"

CLAUDE_MODELS=(
  "claude-opus-4-7"
  "claude-sonnet-4-6"
  "claude-haiku-4-5-20251001"
  "claude-haiku-4-10-20250414"
  "claude-sonnet-4-20250514"
  "claude-opus-4-20250514"
)
CLAUDE_DISPLAY=(
  "Claude Opus 4.7 (latest)"
  "Claude Sonnet 4.6 (latest)"
  "Claude Haiku 4.5 (latest)"
  "Claude Haiku 4 (older)"
  "Claude Sonnet 4 (older)"
  "Claude Opus 4 (older)"
)

CODEX_MODELS=(
  "o4-mini"
  "o3"
  "gpt-4.1"
  "gpt-4o"
  "gpt-4o-mini"
)
CODEX_DISPLAY=(
  "o4-mini (latest)"
  "o3"
  "GPT-4.1"
  "GPT-4o"
  "GPT-4o Mini"
)

OPENCODE_CLOUD_MODELS=(
  "anthropic/claude-opus-4-7"
  "anthropic/claude-sonnet-4-6"
  "anthropic/claude-haiku-4-5-20251001"
  "openai/o4-mini"
  "openai/gpt-4o"
)
OPENCODE_CLOUD_DISPLAY=(
  "Claude Opus 4.7 (Anthropic)"
  "Claude Sonnet 4.6 (Anthropic)"
  "Claude Haiku 4.5 (Anthropic)"
  "o4-mini (OpenAI)"
  "GPT-4o (OpenAI)"
)

AIDER_CLOUD_MODELS=(
  "claude-opus-4-7"
  "claude-sonnet-4-6"
  "claude-haiku-4-5-20251001"
  "o4-mini"
  "gpt-4o"
)
AIDER_CLOUD_DISPLAY=(
  "Claude Opus 4.7 (Anthropic)"
  "Claude Sonnet 4.6 (Anthropic)"
  "Claude Haiku 4.5 (Anthropic)"
  "o4-mini (OpenAI)"
  "GPT-4o (OpenAI)"
)

# ── Helpers ────────────────────────────────────────────────────────
save_env() {
  local backup_file
  backup_file="$(mktemp)"
  for var in ANTHROPIC_MODEL ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN \
             OPENAI_MODEL OPENAI_BASE_URL OPENAI_API_KEY \
             OPENCODE_CONFIG; do
    if [[ -n "${!var:-}" ]]; then
      echo "${var}=${!var}" >> "$backup_file"
    else
      echo "# No ${var} was set" >> "$backup_file"
    fi
  done
  echo "$backup_file"
}

restore_env() {
  local backup_file="$1"
  if [[ -f "$backup_file" ]]; then
    unset ANTHROPIC_MODEL ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN \
          OPENAI_MODEL OPENAI_BASE_URL OPENAI_API_KEY \
          OPENCODE_CONFIG 2>/dev/null || true
    while IFS='=' read -r key value; do
      [[ "$key" =~ ^# ]] && continue
      [[ -z "$key" ]] && continue
      export "$key"="$value"
    done < "$backup_file"
    rm -f "$backup_file"
    ENV_BACKUP_FILE=""
  fi
}

is_local() {
  [[ "$LM_STUDIO_URL" =~ ^https?://(localhost|127\.[0-9]+\.[0-9]+\.[0-9]+)(:[0-9]+)?(/.*)?$ ]]
}

cleanup() {
  if [[ -n "${OPENCODE_CONFIG_FILE:-}" ]]; then
    rm -f "$OPENCODE_CONFIG_FILE"
    OPENCODE_CONFIG_FILE=""
  fi
  if [[ -n "${LOADED_LOCAL_MODEL:-}" ]] && is_local && command -v lms >/dev/null 2>&1; then
    echo ""
    echo "Unloading local model: ${LOADED_LOCAL_MODEL}..."
    lms unload "${LOADED_LOCAL_MODEL}" 2>/dev/null || true
  fi
  if [[ -n "${ENV_BACKUP_FILE:-}" ]]; then
    restore_env "$ENV_BACKUP_FILE"
    echo "[$(date '+%H:%M:%S')] Restored original environment."
  fi
}

# ── Fetch local models from LM Studio ──────────────────────────────
fetch_local_models() {
  local json
  json="$(curl -s "$LM_STUDIO_MODELS_API" 2>/dev/null)" || {
    echo ""
    return 1
  }
  echo "$json"
}

# Format a human-readable size string
format_size() {
  local bytes="$1"
  if (( bytes >= 1073741824 )); then
    printf "%.1f GB" "$(echo "scale=1; $bytes / 1073741824" | bc)"
  elif (( bytes >= 1048576 )); then
    printf "%.1f MB" "$(echo "scale=1; $bytes / 1048576" | bc)"
  else
    printf "%d KB" "$(echo "scale=0; $bytes / 1024" | bc)"
  fi
}

# ── Main ───────────────────────────────────────────────────────────
main() {
  local BACKEND="${1:-claude}"
  case "$BACKEND" in
    claude|codex|opencode|aider) ;;
    *) echo "Usage: llmc [claude|codex|opencode|aider] [local-llm-url]" >&2; exit 1 ;;
  esac
  local raw_url="${2:-}"
  if [[ -n "$raw_url" ]]; then
    if [[ "$raw_url" =~ ^https?:// ]]; then
      LM_STUDIO_URL="$raw_url"
    else
      LM_STUDIO_URL="http://${raw_url}:1234"
    fi
  fi
  LM_STUDIO_MODELS_API="${LM_STUDIO_URL}/api/v1/models"

  local -a CLOUD_MODELS CLOUD_DISPLAY
  case "$BACKEND" in
    claude)
      CLOUD_MODELS=("${CLAUDE_MODELS[@]}")
      CLOUD_DISPLAY=("${CLAUDE_DISPLAY[@]}")
      ;;
    codex)
      CLOUD_MODELS=("${CODEX_MODELS[@]}")
      CLOUD_DISPLAY=("${CODEX_DISPLAY[@]}")
      ;;
    opencode)
      CLOUD_MODELS=("${OPENCODE_CLOUD_MODELS[@]}")
      CLOUD_DISPLAY=("${OPENCODE_CLOUD_DISPLAY[@]}")
      ;;
    aider)
      CLOUD_MODELS=("${AIDER_CLOUD_MODELS[@]}")
      CLOUD_DISPLAY=("${AIDER_CLOUD_DISPLAY[@]}")
      ;;
  esac

  echo "=============================================="
  echo "  llmc — LLM Launcher (${BACKEND})"
  echo "=============================================="
  echo ""

  # Save environment before any changes
  OPENCODE_CONFIG_FILE=""
  ENV_BACKUP_FILE="$(save_env)"
  trap cleanup EXIT

  # ── Fetch local models ─────────────────────────────────────────
  local local_json
  if ! local_json="$(fetch_local_models)"; then
    echo "Warning: Cannot connect to LM Studio at ${LM_STUDIO_URL}"
    echo "  Make sure LM Studio is running with its local server enabled."
    echo ""
  fi

  # Parse local LLMs into arrays
  local -a local_keys=() local_names=() local_archs=()
  local -a local_quants=() local_sizes=() local_contexts=()
  local -a local_vision=() local_tooluse=() local_reasoning=()
  local -a local_loaded=() local_variants=()

  if [[ -n "$local_json" ]]; then
    eval "$(python3 -c "
import json, sys

models = json.loads(sys.argv[1]).get('models', [])
llms = [m for m in models if m.get('type') == 'llm']

print('local_keys=(')
for m in llms:
    print(f'    \"{m[\"key\"]}\"')
print(')')

print('local_names=(')
for m in llms:
    print(f'    \"{m.get(\"display_name\", m[\"key\"])}\"')
print(')')

print('local_archs=(')
for m in llms:
    print(f'    \"{m.get(\"architecture\", \"?\")}\"')
print(')')

print('local_quants=(')
for m in llms:
    q = m.get('quantization', {})
    print(f'    \"{q.get(\"name\", \"?\")} ({q.get(\"bits_per_weight\", \"?\")}bit)\"')
print(')')

print('local_sizes=(')
for m in llms:
    print(f'    \"{m.get(\"size_bytes\", 0)}\"')
print(')')

print('local_contexts=(')
for m in llms:
    print(f'    \"{m.get(\"max_context_length\", 0)}\"')
print(')')

print('local_vision=(')
for m in llms:
    cap = m.get('capabilities', {})
    print(f'    \"{cap.get(\"vision\", False)}\"')
print(')')

print('local_tooluse=(')
for m in llms:
    cap = m.get('capabilities', {})
    print(f'    \"{cap.get(\"trained_for_tool_use\", False)}\"')
print(')')

print('local_reasoning=(')
for m in llms:
    r = m.get('capabilities', {}).get('reasoning', {})
    print(f'    \"{r.get(\"default\", \"off\")}\"')
print(')')

print('local_loaded=(')
for m in llms:
    inst = m.get('loaded_instances', [])
    print(f'    \"{len(inst)}\"')
print(')')

print('local_variants=(')
for m in llms:
    variants = m.get('variants', [])
    sel = m.get('selected_variant', '')
    if sel:
        print(f'    \"{sel}\"')
    elif variants:
        print(f'    \"{variants[0]}\"')
    else:
        print('    \"\"')
print(')')
" "$local_json")"
  fi

  local num_local=${#local_keys[@]}

  # ── Display menu ───────────────────────────────────────────────
  local opt=0
  local total=$(( num_local + ${#CLOUD_MODELS[@]} ))

  if (( num_local > 0 )); then
    echo "Local LLMs (from LM Studio):"
    echo "----------------------------------------------"
    printf "  %-3s  %-28s  %-8s  %-10s  %-8s  %-8s  %s\n" "#" "Name" "Arch" "Quant" "Size" "Context" "Loaded"
    printf "  %-3s  %-28s  %-8s  %-10s  %-8s  %-8s  %s\n" "---" "----------------------------" "--------" "----------" "--------" "--------" "------"
    for (( i = 0; i < num_local; i++ )); do
      local loaded_marker=""
      if (( ${local_loaded[$i]} > 0 )); then
        loaded_marker=" [LOADED]"
      fi
      printf "  %-3s  %-28s  %-8s  %-10s  %-8s  %-8s  %s\n" \
        "$((i + 1))" \
        "${local_names[$i]:-${local_keys[$i]}}" \
        "${local_archs[$i]}" \
        "${local_quants[$i]}" \
        "$(format_size ${local_sizes[$i]})" \
        "${local_contexts[$i]}" \
        "${loaded_marker}"
    done
    echo ""
  else
    echo "No local LLMs found from LM Studio."
    echo ""
  fi

  local cloud_label
  case "$BACKEND" in
    claude)    cloud_label="Cloud LLMs (Anthropic API)" ;;
    codex)     cloud_label="Cloud LLMs (OpenAI API)" ;;
    opencode)  cloud_label="Cloud LLMs (opencode)" ;;
    aider)     cloud_label="Cloud LLMs (aider)" ;;
  esac

  echo "${cloud_label}:"
  echo "----------------------------------------------"
  for (( i = 0; i < ${#CLOUD_MODELS[@]}; i++ )); do
    local idx=$(( num_local + i + 1 ))
    printf "  %-3s  %-35s  (%s)\n" "$idx" "${CLOUD_DISPLAY[$i]}" "${CLOUD_MODELS[$i]}"
  done
  echo ""
  printf "  %-3s  %s\n" "Q/E" "Quit / Exit"
  echo ""
  echo "----------------------------------------------"

  # ── Prompt for selection ───────────────────────────────────────
  read -p "Choose a model (1-$total, Q/E to quit): " opt

  if [[ "$opt" == "q" || "$opt" == "Q" || "$opt" == "e" || "$opt" == "E" ]]; then
    echo "Goodbye."
    return 0
  fi

  if ! [[ "$opt" =~ ^[0-9]+$ ]] || (( opt < 1 )) || (( opt > total )); then
    echo "Invalid selection."
    return 1
  fi

  local model_flag=""
  local model_display=""

  if (( opt <= num_local )); then
    # Local model from LM Studio
    local idx=$(( opt - 1 ))
    local key="${local_keys[$idx]}"
    local variant="${local_variants[$idx]:-$key}"
    case "$BACKEND" in
      claude)    model_flag="openai/${variant}" ;;
      codex)     model_flag="${variant}" ;;
      opencode)  model_flag="lmstudio/${variant}" ;;
      aider)     model_flag="openai/${variant}" ;;
    esac
    model_display="${local_names[$idx]:-$key} (local via LM Studio)"

    if is_local && command -v lms >/dev/null 2>&1; then
      for (( j = 0; j < num_local; j++ )); do
        if (( ${local_loaded[$j]} > 0 )); then
          echo "Unloading ${local_names[$j]:-${local_keys[$j]}}..."
          lms unload "${local_keys[$j]}" 2>/dev/null || true
        fi
      done
      echo "Loading ${local_names[$idx]:-$key}..."
      lms load "$key"
      LOADED_LOCAL_MODEL="$key"
    elif is_local; then
      echo "Warning: 'lms' command not found; skipping model load/unload."
    else
      echo "Note: remote LM Studio URL — skipping lms load/unload."
    fi

    case "$BACKEND" in
      claude)
        export ANTHROPIC_BASE_URL="${LM_STUDIO_URL}"
        export ANTHROPIC_AUTH_TOKEN="lmstudio"
        ;;
      codex)
        export OPENAI_BASE_URL="${LM_STUDIO_URL}/v1"
        export OPENAI_API_KEY="${OPENAI_API_KEY:-lmstudio}"
        ;;
      aider)
        export OPENAI_BASE_URL="${LM_STUDIO_URL}/v1"
        export OPENAI_API_KEY="${OPENAI_API_KEY:-lmstudio}"
        ;;
      opencode)
        OPENCODE_CONFIG_FILE="$(mktemp /tmp/llmc-opencode.XXXXXX.json)"
        python3 -c "
import json, sys
config = {
  'provider': {
    'lmstudio': {
      'npm': '@ai-sdk/openai-compatible',
      'name': 'LM Studio',
      'options': {'baseURL': sys.argv[3] + '/v1'},
      'models': {sys.argv[1]: {'name': sys.argv[2]}}
    }
  }
}
print(json.dumps(config, indent=2))
" "$variant" "${local_names[$idx]:-$key}" "$LM_STUDIO_URL" > "$OPENCODE_CONFIG_FILE"
        export OPENCODE_CONFIG="$OPENCODE_CONFIG_FILE"
        ;;
    esac

    echo "Using local model: ${model_display}"
    echo "  Base URL:  ${LM_STUDIO_URL}"
    echo "  Model:     ${variant}"
  else
    # Cloud model
    local idx=$(( opt - num_local - 1 ))
    model_flag="${CLOUD_MODELS[$idx]}"
    model_display="${CLOUD_DISPLAY[$idx]}"

    case "$BACKEND" in
      claude)
        unset ANTHROPIC_BASE_URL
        unset ANTHROPIC_AUTH_TOKEN
        ;;
      codex)
        unset OPENAI_BASE_URL
        ;;
      aider)
        unset OPENAI_BASE_URL
        ;;
      opencode)
        unset OPENCODE_CONFIG
        ;;
    esac

    echo "Using cloud model: ${model_display}"
    echo "  Model:     ${model_flag}"
  fi

  echo ""
  echo "Starting ${BACKEND}..."
  echo ""

  # ── Run the selected CLI ────────────────────────────────────────
  case "$BACKEND" in
    claude)
      export ANTHROPIC_MODEL="${model_flag}"
      claude
      ;;
    codex)
      codex --model "${model_flag}"
      ;;
    aider)
      aider --model "${model_flag}"
      ;;
    opencode)
      opencode -m "${model_flag}"
      ;;
  esac

  # After the CLI exits, the EXIT trap fires and restores environment
}

main "$@"
