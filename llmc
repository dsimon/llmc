# ── Load cloud models from ~/.llmc/config.json ─────────────────────
# Populates: CLOUD_MODEL_IDS, CLOUD_DISPLAY, CLOUD_PROV_IDS,
#            CLOUD_PROV_TYPES, CLOUD_API_KEYS, CLOUD_BASE_URLS
load_cloud_config() {
  local backend="$1"
  CLOUD_MODEL_IDS=()
  CLOUD_DISPLAY=()
  CLOUD_PROV_IDS=()
  CLOUD_PROV_TYPES=()
  CLOUD_API_KEYS=()
  CLOUD_BASE_URLS=()

  [[ ! -f "$LLMC_CONFIG" ]] && return 0

  local tmppy
  tmppy="$(mktemp /tmp/llmc-cfg.XXXXXX.py)"
  cat > "$tmppy" << 'PYEOF'
import json, sys

config_file, backend = sys.argv[1], sys.argv[2]

try:
    with open(config_file) as f:
        cfg = json.load(f)
except Exception as e:
    sys.stderr.write(f'llmc: config error: {e}\n')
    sys.exit(0)

providers = cfg.get('providers', {})
models_raw = cfg.get('models', {}).get(backend, [])
models = models_raw.get('list', []) if isinstance(models_raw, dict) else models_raw

def sq(s):
    return "'" + str(s).replace("'", "'\\''") + "'"

arrays = [
    ('CLOUD_MODEL_IDS',  [m.get('model', '')                                                      for m in models]),
    ('CLOUD_PROV_IDS',   [m.get('provider', '')                                                   for m in models]),
    ('CLOUD_PROV_TYPES', [providers.get(m.get('provider',''), {}).get('type', 'openai_compatible') for m in models]),
    ('CLOUD_API_KEYS',   [providers.get(m.get('provider',''), {}).get('api_key', '')               for m in models]),
    ('CLOUD_BASE_URLS',  [providers.get(m.get('provider',''), {}).get('base_url', '')              for m in models]),
    ('CLOUD_DISPLAY',    [
        m.get('display', m.get('model', '')) + ' ['
        + providers.get(m.get('provider',''), {}).get('name', m.get('provider','')) + ']'
        for m in models
    ]),
]

for name, values in arrays:
    print(f'{name}=(')
    for v in values:
        print(f'  {sq(v)}')
    print(')')
PYEOF
  eval "$(python3 "$tmppy" "$LLMC_CONFIG" "$backend")"
  rm -f "$tmppy"
}

# ── Main ───────────────────────────────────────────────────────────
main() {
  local BACKEND="${1:-claude}"
  case "$BACKEND" in
    claude|codex|opencode|aider) ;;
    *) echo "Usage: llmc [claude|codex|opencode|aider] [local-llm-url]" >&2; exit 1 ;;
  esac
  local raw_url="${2:-}"
  if [[ -n "$raw_url" ]]; then
    if [[ "$raw_url" =~ ^https?:// ]]; then
      LM_STUDIO_URL="$raw_url"
    else
      LM_STUDIO_URL="http://${raw_url}:1234"
    fi
  fi
  LM_STUDIO_MODELS_API="${LM_STUDIO_URL}/api/v1/models"

  ensure_config
  local -a CLOUD_MODEL_IDS CLOUD_DISPLAY CLOUD_PROV_IDS CLOUD_PROV_TYPES CLOUD_API_KEYS CLOUD_BASE_URLS
  load_cloud_config "$BACKEND"

  echo "=============================================="
  echo "  llmc — LLM Launcher (${BACKEND})"
  echo "=============================================="
  echo ""

  # Save environment before any changes
  OPENCODE_CONFIG_FILE=""
  PROXY_PID=""
  PROXY_SCRIPT=""
  PROXY_PORT=""
  LMS_DAEMON_STARTED=""
  ENV_BACKUP_FILE="$(save_env)"
  trap cleanup EXIT

  # ── Start LM Studio daemon if not already running ──────────────
  if is_local && command -v lms >/dev/null 2>&1; then
    if ! curl -sf "$LM_STUDIO_MODELS_API" >/dev/null 2>&1; then
      echo "Starting LM Studio daemon..."
      lms daemon up 2>/dev/null || true
      LMS_DAEMON_STARTED=1
      local elapsed=0
      while (( elapsed < 20 )) && ! curl -sf "$LM_STUDIO_MODELS_API" >/dev/null 2>&1; do
        sleep 0.5
        (( elapsed++ ))
      done
    fi
  fi

  # ── Fetch local models ─────────────────────────────────────────
  local local_json
  local_json="$(fetch_local_models)" || true

  # Parse local LLMs into arrays
  local -a local_keys=() local_names=() local_archs=()
  local -a local_quants=() local_sizes=() local_contexts=()
  local -a local_vision=() local_tooluse=() local_reasoning=()
  local -a local_loaded=() local_variants=()

  if [[ -n "$local_json" ]]; then
    eval "$(python3 -c "
import json, sys

models = json.loads(sys.argv[1]).get('models', [])
llms = [m for m in models if m.get('type') == 'llm']

def sq(s):
    return \"'\" + str(s).replace(\"'\", \"'\\\\''\" ) + \"'\"

print('local_keys=(')
for m in llms:
    print(f'    {sq(m[\"key\"])}')
print(')')

print('local_names=(')
for m in llms:
    print(f'    {sq(m.get(\"display_name\", m[\"key\"]))}')
print(')')

print('local_archs=(')
for m in llms:
    print(f'    {sq(m.get(\"architecture\", \"?\"))}')
print(')')

print('local_quants=(')
for m in llms:
    q = m.get('quantization', {})
    print(f'    {sq(str(q.get(\"name\", \"?\")) + \" (\" + str(q.get(\"bits_per_weight\", \"?\")) + \"bit)\")}')
print(')')

print('local_sizes=(')
for m in llms:
    print(f'    {sq(m.get(\"size_bytes\", 0))}')
print(')')

print('local_contexts=(')
for m in llms:
    print(f'    {sq(m.get(\"max_context_length\", 0))}')
print(')')

print('local_vision=(')
for m in llms:
    cap = m.get('capabilities', {})
    print(f'    {sq(cap.get(\"vision\", False))}')
print(')')

print('local_tooluse=(')
for m in llms:
    cap = m.get('capabilities', {})
    print(f'    {sq(cap.get(\"trained_for_tool_use\", False))}')
print(')')

print('local_reasoning=(')
for m in llms:
    r = m.get('capabilities', {}).get('reasoning', {})
    print(f'    {sq(r.get(\"default\", \"off\"))}')
print(')')

print('local_loaded=(')
for m in llms:
    inst = m.get('loaded_instances', [])
    print(f'    {sq(len(inst))}')
print(')')

print('local_variants=(')
for m in llms:
    variants = m.get('variants', [])
    sel = m.get('selected_variant', '')
    if sel:
        print(f'    {sq(sel)}')
    elif variants:
        print(f'    {sq(variants[0])}')
    else:
        print(\"    ''\")
print(')')
" "$local_json")"
  fi

  local num_local=${#local_keys[@]}

  # ── Display menu ───────────────────────────────────────────────
  local opt=0
  local total=$(( num_local + ${#CLOUD_MODEL_IDS[@]} ))

  printf "  %-3s  %s\n" "0" "Default model (no override)"
  echo ""

  if (( num_local > 0 )); then
    echo "Local LLMs (from LM Studio):"
    echo "----------------------------------------------"
    printf "  %-3s  %-28s  %-8s  %-10s  %-8s  %-8s  %s\n" "#" "Name" "Arch" "Quant" "Size" "Context" "Loaded"
    printf "  %-3s  %-28s  %-8s  %-10s  %-8s  %-8s  %s\n" "---" "----------------------------" "--------" "----------" "--------" "--------" "------"
    for (( i = 0; i < num_local; i++ )); do
      local loaded_marker=""
      if (( ${local_loaded[$i]} > 0 )); then
        loaded_marker=" [LOADED]"
      fi
      printf "  %-3s  %-28s  %-8s  %-10s  %-8s  %-8s  %s\n" \
        "$((i + 1))" \
        "${local_names[$i]:-${local_keys[$i]}}" \
        "${local_archs[$i]}" \
        "${local_quants[$i]}" \
        "$(format_size ${local_sizes[$i]})" \
        "${local_contexts[$i]}" \
        "${loaded_marker}"
    done
    echo ""
  else
    echo "No local LLMs found from LM Studio."
    echo ""
  fi

  local cloud_label
  case "$BACKEND" in
    claude)    cloud_label="Cloud LLMs (Anthropic API)" ;;
    codex)     cloud_label="Cloud LLMs (OpenAI API)" ;;
    opencode)  cloud_label="Cloud LLMs (opencode)" ;;
    aider)     cloud_label="Cloud LLMs (aider)" ;;
  esac

  echo "${cloud_label}:"
  echo "----------------------------------------------"
  if (( ${#CLOUD_MODEL_IDS[@]} > 0 )); then
    for (( i = 0; i < ${#CLOUD_MODEL_IDS[@]}; i++ )); do
      local idx=$(( num_local + i + 1 ))
      printf "  %-3s  %-40s  (%s)\n" "$idx" "${CLOUD_DISPLAY[$i]}" "${CLOUD_MODEL_IDS[$i]}"
    done
  else
    echo "  (none configured — edit ${LLMC_CONFIG})"
  fi
  echo ""
  printf "  %-3s  %s\n" "Q/E" "Quit / Exit"
  echo ""
  echo "----------------------------------------------"

  # ── Prompt for selection ───────────────────────────────────────
  read -p "Choose a model (0-$total, Q/E to quit) [0]: " opt
  [[ -z "$opt" ]] && opt=0

  if [[ "$opt" == "q" || "$opt" == "Q" || "$opt" == "e" || "$opt" == "E" ]]; then
    echo "Goodbye."
    return 0
  fi

  if ! [[ "$opt" =~ ^[0-9]+$ ]] || (( opt < 0 )) || (( opt > total )); then
    echo "Invalid selection."
    return 1
  fi

  local model_flag=""
  local model_display=""

  if (( opt == 0 )); then
    model_display="default (no model override)"
    case "$BACKEND" in
      claude)   unset ANTHROPIC_MODEL ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN ;;
      codex)    unset OPENAI_MODEL OPENAI_BASE_URL ;;
      aider)    unset OPENAI_BASE_URL ;;
      opencode) unset OPENCODE_CONFIG ;;
    esac
    echo "Using ${model_display}"
  elif (( opt <= num_local )); then
    # Local model from LM Studio
    local idx=$(( opt - 1 ))
    local key="${local_keys[$idx]}"
    local variant="${local_variants[$idx]:-$key}"
    case "$BACKEND" in
      claude)    model_flag="openai/${variant}" ;;
      codex)     model_flag="${variant}" ;;
      opencode)  model_flag="lmstudio/${variant}" ;;
      aider)     model_flag="openai/${variant}" ;;
    esac
    model_display="${local_names[$idx]:-$key} (local via LM Studio)"

    if is_local && command -v lms >/dev/null 2>&1; then
      local needs_unload=0
      for (( j = 0; j < num_local; j++ )); do
        if (( ${local_loaded[$j]} > 0 )); then
          echo "Unloading ${local_names[$j]:-${local_keys[$j]}}..."
          needs_unload=1
        fi
      done
      if (( needs_unload )); then
        lms unload --all 2>/dev/null || true
      fi
      echo "Loading ${local_names[$idx]:-$key}..."
      lms load "$key"
      LOADED_LOCAL_MODEL="$key"
    elif is_local; then
      echo "Warning: 'lms' command not found; skipping model load/unload."
    else
      echo "Note: remote LM Studio URL — skipping lms load/unload."
    fi

    case "$BACKEND" in
      claude)
        export ANTHROPIC_BASE_URL="${LM_STUDIO_URL}"
        export ANTHROPIC_AUTH_TOKEN="lmstudio"
        ;;
      codex)
        export OPENAI_BASE_URL="${LM_STUDIO_URL}/v1"
        export OPENAI_API_KEY="${OPENAI_API_KEY:-lmstudio}"
        ;;
      aider)
        export OPENAI_BASE_URL="${LM_STUDIO_URL}/v1"
        export OPENAI_API_KEY="${OPENAI_API_KEY:-lmstudio}"
        ;;
      opencode)
        OPENCODE_CONFIG_FILE="$(mktemp /tmp/llmc-opencode.XXXXXX.json)"
        python3 -c "
import json, sys
config = {
  'provider': {
    'lmstudio': {
      'npm': '@ai-sdk/openai-compatible',
      'name': 'LM Studio',
      'options': {'baseURL': sys.argv[3] + '/v1'},
      'models': {sys.argv[1]: {'name': sys.argv[2]}}
    }
  }
}
print(json.dumps(config, indent=2))
" "$variant" "${local_names[$idx]:-$key}" "$LM_STUDIO_URL" > "$OPENCODE_CONFIG_FILE"
        export OPENCODE_CONFIG="$OPENCODE_CONFIG_FILE"
        ;;
    esac

    echo "Using local model: ${model_display}"
    echo "  Base URL:  ${LM_STUDIO_URL}"
    echo "  Model:     ${variant}"
  else
    # Cloud model from config
    local cidx=$(( opt - num_local - 1 ))
    local raw_model="${CLOUD_MODEL_IDS[$cidx]}"
    local prov_id="${CLOUD_PROV_IDS[$cidx]}"
    local ptype="${CLOUD_PROV_TYPES[$cidx]}"
    local api_key="${CLOUD_API_KEYS[$cidx]}"
    local base_url="${CLOUD_BASE_URLS[$cidx]}"
    model_display="${CLOUD_DISPLAY[$cidx]}"

    case "$BACKEND" in
      claude)
        unset ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN OPENAI_BASE_URL OPENAI_API_KEY
        if [[ "$ptype" == "anthropic" ]]; then
          model_flag="$raw_model"
          [[ -n "$api_key" ]] && export ANTHROPIC_API_KEY="$api_key"
        else
          # LiteLLM proxy accepts Anthropic-format requests from Claude Code
          # and translates them to OpenAI chat/completions for the provider.
          model_flag="$raw_model"
          if [[ -z "$api_key" ]]; then
            echo "  ⚠  API key not set — add api_key for this provider in ${LLMC_CONFIG}"
          fi
          start_litellm_proxy "$raw_model" "$base_url" "$api_key" || return 1
          export ANTHROPIC_BASE_URL="http://127.0.0.1:${PROXY_PORT}"
          # Override session token so Claude Code uses ANTHROPIC_BASE_URL without
          # triggering the ANTHROPIC_API_KEY vs. session conflict warning.
          export ANTHROPIC_AUTH_TOKEN="llmc-proxy"
          unset ANTHROPIC_API_KEY
          echo "  Proxy:     localhost:${PROXY_PORT} → ${base_url}"
          echo "  Log:       /tmp/llmc-litellm.log"
          echo ""
        fi
        ;;
      codex)
        unset OPENAI_BASE_URL
        model_flag="$raw_model"
        [[ -n "$api_key" ]] && export OPENAI_API_KEY="$api_key"
        [[ -n "$base_url" ]] && export OPENAI_BASE_URL="$base_url"
        ;;
      aider)
        unset OPENAI_BASE_URL
        if [[ "$ptype" == "anthropic" ]]; then
          model_flag="$raw_model"
          [[ -n "$api_key" ]] && export ANTHROPIC_API_KEY="$api_key"
        else
          model_flag="openai/${raw_model}"
          [[ -n "$api_key" ]] && export OPENAI_API_KEY="$api_key"
          [[ -n "$base_url" ]] && export OPENAI_BASE_URL="$base_url"
        fi
        ;;
      opencode)
        unset OPENCODE_CONFIG
        if [[ "$ptype" == "anthropic" || "$ptype" == "openai" ]]; then
          model_flag="$raw_model"
          [[ "$ptype" == "anthropic" && -n "$api_key" ]] && export ANTHROPIC_API_KEY="$api_key"
          [[ "$ptype" == "openai"    && -n "$api_key" ]] && export OPENAI_API_KEY="$api_key"
        else
          OPENCODE_CONFIG_FILE="$(mktemp /tmp/llmc-opencode.XXXXXX.json)"
          _LLMC_API_KEY="$api_key" python3 -c "
import json, sys, os
prov_id, model_id, display, base_url = sys.argv[1:]
api_key = os.environ.get('_LLMC_API_KEY', '')
config = {
  'provider': {
    prov_id: {
      'npm': '@ai-sdk/openai-compatible',
      'name': display,
      'options': {'baseURL': base_url, 'apiKey': api_key},
      'models': {model_id: {'name': display}}
    }
  }
}
print(json.dumps(config, indent=2))
" "$prov_id" "$raw_model" "$model_display" "$base_url" > "$OPENCODE_CONFIG_FILE"
          export OPENCODE_CONFIG="$OPENCODE_CONFIG_FILE"
          model_flag="${prov_id}/${raw_model}"
        fi
        ;;
    esac

    echo "Using cloud model: ${model_display}"
    echo "  Model:     ${raw_model}"
  fi

  echo ""
  echo "Starting ${BACKEND}..."
  echo ""

  # ── Run the selected CLI ────────────────────────────────────────
  case "$BACKEND" in
    claude)
      if [[ -n "${model_flag}" ]]; then
        claude --model "${model_flag}"
      else
        claude
      fi
      ;;
    codex)
      if [[ -n "${model_flag}" ]]; then
        codex --model "${model_flag}"
      else
        codex
      fi
      ;;
    aider)
      if [[ -n "${model_flag}" ]]; then
        aider --model "${model_flag}"
      else
        aider
      fi
      ;;
    opencode)
      if [[ -n "${model_flag}" ]]; then
        opencode -m "${model_flag}"
      else
        opencode
      fi
      ;;
  esac

  # After the CLI exits, the EXIT trap fires and restores environment
}

main "$@"
